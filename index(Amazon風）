<script>
  // Category chip toggle
  document.querySelectorAll('.chip').forEach(c=>{
    c.addEventListener('click',()=>{
      document.querySelectorAll('.chip').forEach(x=>x.classList.remove('active'));
      c.classList.add('active');
    });
  });

  // Row scroll buttons
  document.querySelectorAll('.row-btn').forEach(btn=>{
    btn.addEventListener('click',()=>{
      const row = document.getElementById(btn.dataset.target);
      if(!row) return;
      const dir = btn.classList.contains('left') ? -1 : 1;
      row.scrollBy({left: dir * row.clientWidth * 0.9, behavior:'smooth'});
    });
  });

  // Reveal on scroll
  const io = new IntersectionObserver(entries=>{
    entries.forEach(e=>{ if(e.isIntersecting){ e.target.classList.add('in'); io.unobserve(e.target); }});
  },{threshold:.12});
  document.querySelectorAll('.reveal').forEach(el=>io.observe(el));

  // Favorite heart toggle
  document.querySelectorAll('.fav').forEach(f=>{
    f.addEventListener('click',e=>{
      e.preventDefault(); e.stopPropagation();
      f.style.color = f.style.color === 'rgb(229, 9, 20)' ? '#ff3b53' : '#e50914';
      f.animate(
        [{transform:'scale(1)'},{transform:'scale(1.4)'},{transform:'scale(1)'}],
        {duration:380, easing:'cubic-bezier(.2,.8,.2,1.4)'}
      );
    });
  });
</script>
