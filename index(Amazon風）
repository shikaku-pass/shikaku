<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>といとく｜資格を、解いて、つかむ。</title>
<meta name="description" content="ITパスポート・宅建・FP・簿記など59資格の4択問題集が完全無料。登録不要で今すぐスタート。">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700;900&family=Inter:wght@600;800&display=swap" rel="stylesheet">
<style>
/* =========================================================
   といとく — Mercari × Amazon × Netflix inspired UI
   ========================================================= */
:root{
  --bg:#ffffff;
  --bg-soft:#f6f7f9;
  --bg-dark:#0b0d12;
  --ink:#1a1c20;
  --ink-2:#4b5563;
  --ink-3:#8a8f98;
  --line:#e7e9ee;
  --brand:#ff3b53;        /* Mercari red */
  --brand-2:#ff6a3d;      /* Amazon orange */
  --gold:#ffb400;         /* Amazon star */
  --netflix:#e50914;      /* Netflix red */
  --accent:#1f6feb;
  --shadow-sm:0 1px 2px rgba(15,17,21,.06);
  --shadow-md:0 8px 24px rgba(15,17,21,.08);
  --shadow-lg:0 20px 50px rgba(15,17,21,.18);
  --radius-s:10px;
  --radius:14px;
  --radius-l:22px;
}

*{box-sizing:border-box}
html,body{margin:0;padding:0}
body{
  font-family:"Noto Sans JP","Inter",-apple-system,BlinkMacSystemFont,sans-serif;
  color:var(--ink);
  background:var(--bg);
  -webkit-font-smoothing:antialiased;
  line-height:1.6;
  padding-bottom:88px; /* space for bottom nav on mobile */
}
a{color:inherit;text-decoration:none}
button{font-family:inherit;cursor:pointer;border:none;background:none}
img{max-width:100%;display:block}

/* ---------- Header (Amazon-style top bar) ---------- */
.topbar{
  position:sticky;top:0;z-index:50;
  background:#0f1115;
  color:#fff;
  border-bottom:1px solid #1c1f25;
}
.topbar-inner{
  max-width:1280px;margin:0 auto;
  display:flex;align-items:center;gap:16px;
  padding:12px 20px;
}
.logo{
  display:flex;align-items:center;gap:8px;
  font-family:"Inter","Noto Sans JP";font-weight:900;font-size:22px;
  letter-spacing:-.5px;
  white-space:nowrap;
}
.logo-mark{
  width:34px;height:34px;border-radius:10px;
  background:linear-gradient(135deg,var(--brand),var(--brand-2));
  display:grid;place-items:center;color:#fff;font-weight:900;
  box-shadow:0 4px 14px rgba(255,59,83,.5);
  animation:pulse 2.6s ease-in-out infinite;
}
@keyframes pulse{
  0%,100%{transform:scale(1);box-shadow:0 4px 14px rgba(255,59,83,.5)}
  50%{transform:scale(1.06);box-shadow:0 6px 22px rgba(255,106,61,.65)}
}
.logo-text{background:linear-gradient(90deg,#fff,#ffd6c2);-webkit-background-clip:text;background-clip:text;color:transparent}

.search{
  flex:1;display:flex;align-items:center;
  background:#fff;border-radius:999px;overflow:hidden;
  box-shadow:0 0 0 2px transparent;
  transition:box-shadow .25s ease, transform .25s ease;
}
.search:focus-within{box-shadow:0 0 0 3px var(--brand-2);transform:translateY(-1px)}
.search select{
  border:none;background:#eef0f4;color:#333;
  padding:12px 12px;font-size:13px;outline:none;cursor:pointer;
}
.search input{
  flex:1;border:none;outline:none;padding:12px 14px;font-size:15px;color:#222;
  min-width:0;
}
.search button{
  background:linear-gradient(180deg,#ffb400,#ff8b00);
  color:#1a1c20;font-weight:700;padding:0 18px;height:44px;
  display:flex;align-items:center;gap:6px;
  transition:filter .2s ease;
}
.search button:hover{filter:brightness(1.08)}

.top-actions{display:flex;align-items:center;gap:18px}
.top-action{
  display:flex;flex-direction:column;align-items:center;
  font-size:11px;color:#cfd3da;line-height:1.2;
  padding:6px 4px;border-radius:8px;
  transition:background .2s ease,color .2s ease;
}
.top-action:hover{background:#1c1f25;color:#fff}
.top-action .ic{font-size:18px}
.top-action b{color:#fff;font-size:12px;font-weight:700}

@media (max-width:780px){
  .top-actions{display:none}
  .logo-text{display:none}
}

/* ---------- Sub-nav (categories ribbon, Amazon-style) ---------- */
.subnav{
  background:#171a20;color:#e7e9ee;
  border-bottom:1px solid #20242c;
}
.subnav-inner{
  max-width:1280px;margin:0 auto;
  display:flex;gap:6px;align-items:center;
  padding:8px 20px;overflow-x:auto;
  scrollbar-width:none;
}
.subnav-inner::-webkit-scrollbar{display:none}
.subnav a{
  white-space:nowrap;padding:8px 12px;border-radius:8px;
  font-size:13px;color:#cfd3da;
  transition:background .2s ease,color .2s ease;
}
.subnav a:hover{background:#262a33;color:#fff}
.subnav a.live{color:#ff8b00}
.subnav a.live::before{content:"●";margin-right:6px;color:#ff3b53;animation:blink 1.4s infinite}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.3}}

/* ---------- Hero (Netflix-style) ---------- */
.hero{
  position:relative;
  background:
    radial-gradient(1200px 500px at 20% -10%, rgba(255,106,61,.25), transparent 60%),
    radial-gradient(1000px 500px at 90% 0%, rgba(31,111,235,.22), transparent 60%),
    linear-gradient(180deg,#0b0d12 0%,#15181f 100%);
  color:#fff;
  overflow:hidden;
}
.hero-inner{
  max-width:1280px;margin:0 auto;
  padding:64px 20px 96px;
  display:grid;grid-template-columns:1.2fr .8fr;gap:40px;align-items:center;
}
.hero h1{
  font-size:clamp(32px,5vw,56px);
  line-height:1.15;font-weight:900;margin:0 0 18px;
  letter-spacing:-.5px;
}
.hero h1 .accent{
  background:linear-gradient(90deg,#ff3b53,#ff8b00 60%,#ffb400);
  -webkit-background-clip:text;background-clip:text;color:transparent;
}
.hero p.lead{font-size:17px;color:#cfd3da;max-width:560px;margin:0 0 28px}
.hero-cta{display:flex;gap:12px;flex-wrap:wrap}
.btn{
  display:inline-flex;align-items:center;gap:8px;
  padding:14px 22px;border-radius:999px;font-weight:700;
  transition:transform .2s ease, box-shadow .25s ease, filter .2s ease;
}
.btn-primary{
  background:linear-gradient(135deg,var(--brand),var(--brand-2));
  color:#fff;box-shadow:0 10px 24px rgba(255,59,83,.35);
}
.btn-primary:hover{transform:translateY(-2px);box-shadow:0 14px 30px rgba(255,59,83,.5)}
.btn-ghost{background:rgba(255,255,255,.1);color:#fff;backdrop-filter:blur(6px)}
.btn-ghost:hover{background:rgba(255,255,255,.18)}

.hero-badges{display:flex;gap:10px;margin-top:26px;flex-wrap:wrap}
.badge{
  background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.14);
  padding:8px 14px;border-radius:999px;font-size:13px;color:#e7e9ee;
  display:inline-flex;align-items:center;gap:8px;
}
.badge .dot{width:6px;height:6px;border-radius:999px;background:#22c55e;box-shadow:0 0 0 4px rgba(34,197,94,.25)}

/* Hero floating preview card */
.preview{
  position:relative;perspective:1200px;height:420px;
}
.qcard{
  position:absolute;inset:0;
  background:#fff;color:#1a1c20;border-radius:22px;
  padding:24px;box-shadow:var(--shadow-lg);
  transform:rotate(-3deg);
  animation:float 6s ease-in-out infinite;
}
.qcard::before{
  content:"";position:absolute;inset:-20px;border-radius:32px;
  background:linear-gradient(135deg,rgba(255,59,83,.2),rgba(31,111,235,.2));
  filter:blur(30px);z-index:-1;
}
@keyframes float{
  0%,100%{transform:rotate(-3deg) translateY(0)}
  50%{transform:rotate(-3deg) translateY(-12px)}
}
.qcard .qhead{display:flex;justify-content:space-between;align-items:center;margin-bottom:14px;font-size:12px;color:var(--ink-3)}
.qcard .qtag{background:#fff1ee;color:var(--brand);padding:4px 10px;border-radius:999px;font-weight:700}
.qcard .qtext{font-size:17px;font-weight:700;line-height:1.5;margin-bottom:18px}
.opt{
  border:2px solid var(--line);border-radius:12px;padding:12px 14px;
  margin-bottom:10px;font-size:14px;display:flex;align-items:center;gap:12px;
  transition:all .25s ease;cursor:pointer;
}
.opt:hover{border-color:var(--brand);background:#fff5f6;transform:translateX(4px)}
.opt.correct{border-color:#22c55e;background:#ecfdf5}
.opt .key{
  width:24px;height:24px;border-radius:7px;background:var(--bg-soft);
  display:grid;place-items:center;font-weight:700;font-size:12px;
}
.opt.correct .key{background:#22c55e;color:#fff}
.qcard .qbar{
  margin-top:10px;height:6px;background:#eef0f4;border-radius:99px;overflow:hidden;
}
.qcard .qbar i{
  display:block;height:100%;width:62%;
  background:linear-gradient(90deg,var(--brand),var(--brand-2));
  border-radius:99px;animation:fill 2s ease-out;
}
@keyframes fill{from{width:0}to{width:62%}}

@media (max-width:980px){
  .hero-inner{grid-template-columns:1fr;padding:40px 20px 60px}
  .preview{height:360px;max-width:420px;margin:0 auto}
}

/* ---------- Section base ---------- */
section{max-width:1280px;margin:0 auto;padding:48px 20px}
.section-head{
  display:flex;align-items:flex-end;justify-content:space-between;gap:16px;margin-bottom:18px;
}
.section-head h2{
  font-size:clamp(20px,2.4vw,26px);font-weight:900;margin:0;
  letter-spacing:-.3px;
}
.section-head .sub{color:var(--ink-3);font-size:13px;margin-top:4px}
.section-head .more{color:var(--accent);font-weight:700;font-size:14px}
.section-head .more::after{content:" →";transition:margin .2s ease}
.section-head .more:hover::after{margin-left:6px}

/* ---------- Category chips (Mercari-style pills) ---------- */
.chips{
  display:flex;gap:10px;overflow-x:auto;padding:8px 0 14px;
  scrollbar-width:none;
}
.chips::-webkit-scrollbar{display:none}
.chip{
  flex:0 0 auto;
  display:inline-flex;align-items:center;gap:8px;
  padding:10px 16px;border-radius:999px;
  background:var(--bg-soft);color:var(--ink);
  font-size:14px;font-weight:600;
  border:1px solid var(--line);
  transition:all .2s ease;
}
.chip .ic{font-size:16px}
.chip .count{
  background:#fff;color:var(--ink-3);font-size:11px;font-weight:700;
  padding:2px 8px;border-radius:999px;border:1px solid var(--line);
}
.chip:hover{background:#fff5f6;border-color:var(--brand);color:var(--brand);transform:translateY(-2px)}
.chip.active{background:var(--ink);color:#fff;border-color:var(--ink)}
.chip.active .count{background:#2a2c33;color:#fff;border-color:#2a2c33}

/* ---------- Purpose tiles (Mercari category style) ---------- */
.tiles{
  display:grid;grid-template-columns:repeat(5,1fr);gap:14px;
}
.tile{
  position:relative;overflow:hidden;
  border-radius:var(--radius);
  padding:22px 16px;
  color:#fff;font-weight:800;
  display:flex;flex-direction:column;justify-content:space-between;
  min-height:130px;
  transition:transform .3s ease, box-shadow .3s ease;
  cursor:pointer;
}
.tile:hover{transform:translateY(-6px);box-shadow:var(--shadow-md)}
.tile::after{
  content:"";position:absolute;inset:0;
  background:radial-gradient(120px 80px at 100% 0%, rgba(255,255,255,.25), transparent 70%);
  pointer-events:none;
}
.tile .ic{font-size:28px}
.tile .num{font-size:24px;font-weight:900}
.tile .label{font-size:14px;opacity:.95}
.tile.t1{background:linear-gradient(135deg,#ff3b53,#ff8b00)}
.tile.t2{background:linear-gradient(135deg,#1f6feb,#22d3ee)}
.tile.t3{background:linear-gradient(135deg,#22c55e,#84cc16)}
.tile.t4{background:linear-gradient(135deg,#8b5cf6,#ec4899)}
.tile.t5{background:linear-gradient(135deg,#0ea5e9,#1e40af)}
@media (max-width:880px){.tiles{grid-template-columns:repeat(2,1fr)}}

/* ---------- Netflix-style horizontal row ---------- */
.row-wrap{position:relative;margin:0 -20px;padding:0 20px}
.row{
  display:flex;gap:14px;overflow-x:auto;
  padding:6px 4px 18px;
  scroll-snap-type:x mandatory;
  scrollbar-width:none;
}
.row::-webkit-scrollbar{display:none}
.row > *{scroll-snap-align:start}

.rank-card{
  flex:0 0 320px;
  position:relative;
  background:#fff;border-radius:var(--radius);
  border:1px solid var(--line);
  padding:18px 18px 18px 80px;
  transition:transform .3s ease, box-shadow .3s ease, border-color .3s ease;
  overflow:hidden;
}
.rank-card:hover{
  transform:translateY(-4px) scale(1.01);
  box-shadow:var(--shadow-md);
  border-color:transparent;
}
.rank-num{
  position:absolute;left:-6px;top:14px;
  font-family:"Inter";font-weight:900;font-size:84px;
  line-height:.9;letter-spacing:-6px;
  color:transparent;-webkit-text-stroke:2px var(--ink);
  pointer-events:none;
}
.rank-card.gold .rank-num{-webkit-text-stroke:2px #d4a017;color:rgba(212,160,23,.08)}
.rank-card.silver .rank-num{-webkit-text-stroke:2px #98a2b3;color:rgba(152,162,179,.08)}
.rank-card.bronze .rank-num{-webkit-text-stroke:2px #b45309;color:rgba(180,83,9,.08)}
.rank-card .crown{
  position:absolute;top:14px;right:14px;
  width:28px;height:28px;border-radius:8px;
  display:grid;place-items:center;font-size:14px;color:#fff;
}
.rank-card.gold .crown{background:linear-gradient(135deg,#f7c948,#d4a017)}
.rank-card.silver .crown{background:linear-gradient(135deg,#cbd5e1,#94a3b8)}
.rank-card.bronze .crown{background:linear-gradient(135deg,#fbbf24,#b45309)}
.rank-card h3{font-size:18px;margin:0 0 8px;font-weight:800}
.rank-card .meta{display:flex;gap:14px;color:var(--ink-2);font-size:12px;margin-bottom:12px;flex-wrap:wrap}
.rank-card .meta b{color:var(--ink)}
.rank-card .stars{color:var(--gold);letter-spacing:1px;font-size:14px}
.rank-card .stars .off{color:#e0e3ea}
.rank-card .progress{height:6px;background:#eef0f4;border-radius:99px;overflow:hidden;margin:10px 0 6px}
.rank-card .progress i{display:block;height:100%;background:linear-gradient(90deg,var(--brand),var(--brand-2));border-radius:99px}
.rank-card .progress-label{font-size:11px;color:var(--ink-3)}
.rank-card .start{
  margin-top:14px;
  display:flex;align-items:center;justify-content:space-between;
  padding:10px 14px;border-radius:10px;
  background:#fff5f6;color:var(--brand);font-weight:700;font-size:13px;
  transition:background .2s ease, color .2s ease;
}
.rank-card:hover .start{background:var(--brand);color:#fff}

/* Row scroll buttons */
.row-btn{
  position:absolute;top:50%;transform:translateY(-50%);
  width:42px;height:42px;border-radius:999px;background:#fff;
  box-shadow:var(--shadow-md);display:grid;place-items:center;
  font-size:18px;font-weight:900;color:var(--ink);z-index:5;
  border:1px solid var(--line);
  opacity:0;transition:opacity .2s ease, transform .2s ease;
}
.row-wrap:hover .row-btn{opacity:1}
.row-btn:hover{transform:translateY(-50%) scale(1.1)}
.row-btn.left{left:6px}
.row-btn.right{right:6px}

/* ---------- Beginner grid (Amazon product-card style) ---------- */
.cards{
  display:grid;grid-template-columns:repeat(4,1fr);gap:18px;
}
@media (max-width:980px){.cards{grid-template-columns:repeat(2,1fr)}}
.card{
  background:#fff;border-radius:var(--radius);
  border:1px solid var(--line);
  overflow:hidden;
  transition:transform .3s ease, box-shadow .3s ease;
  display:flex;flex-direction:column;
}
.card:hover{transform:translateY(-6px);box-shadow:var(--shadow-md)}
.card .thumb{
  height:130px;position:relative;overflow:hidden;
  display:grid;place-items:center;color:#fff;font-weight:900;font-size:36px;
  letter-spacing:-1px;
}
.card .thumb::before{
  content:"";position:absolute;inset:0;
  background:radial-gradient(200px 120px at 80% 20%, rgba(255,255,255,.3), transparent 60%);
}
.card .thumb .tag{
  position:absolute;left:12px;top:12px;
  background:rgba(0,0,0,.5);backdrop-filter:blur(6px);
  color:#fff;font-size:11px;font-weight:700;
  padding:4px 8px;border-radius:6px;
}
.card .thumb .fav{
  position:absolute;right:10px;top:10px;
  width:32px;height:32px;border-radius:999px;background:rgba(255,255,255,.92);
  display:grid;place-items:center;font-size:14px;color:#ff3b53;
  transition:transform .2s ease;
}
.card .thumb .fav:hover{transform:scale(1.15)}
.card .body{padding:14px 14px 16px;flex:1;display:flex;flex-direction:column}
.card h4{font-size:15px;font-weight:800;margin:0 0 8px;line-height:1.4}
.card .stars{color:var(--gold);font-size:13px;letter-spacing:.5px}
.card .stars .off{color:#e0e3ea}
.card .stars .reviews{color:var(--ink-3);font-size:12px;margin-left:6px;font-weight:500}
.card .meta-row{display:flex;justify-content:space-between;color:var(--ink-2);font-size:12px;margin:8px 0}
.card .price{
  font-family:"Inter";font-size:22px;font-weight:900;color:var(--ink);
}
.card .price small{font-size:12px;color:var(--ink-3);font-weight:500;margin-left:2px}
.card .free{color:#22c55e}
.card .start-btn{
  margin-top:auto;
  padding:10px;border-radius:10px;
  background:linear-gradient(180deg,#ffb400,#ff8b00);
  color:#1a1c20;font-weight:800;font-size:13px;
  text-align:center;
  transition:filter .2s ease, transform .2s ease;
}
.card .start-btn:hover{filter:brightness(1.05);transform:translateY(-1px)}

/* Thumb color variants */
.bg-it{background:linear-gradient(135deg,#1f6feb,#22d3ee)}
.bg-fp{background:linear-gradient(135deg,#22c55e,#84cc16)}
.bg-bk{background:linear-gradient(135deg,#8b5cf6,#ec4899)}
.bg-ai{background:linear-gradient(135deg,#ff3b53,#ff8b00)}
.bg-tb{background:linear-gradient(135deg,#0ea5e9,#1e40af)}
.bg-ap{background:linear-gradient(135deg,#0f766e,#10b981)}
.bg-fp2{background:linear-gradient(135deg,#f97316,#ef4444)}
.bg-sec{background:linear-gradient(135deg,#7c3aed,#3b82f6)}

/* ---------- Career section (Netflix-like dark) ---------- */
.career{
  background:linear-gradient(180deg,#0b0d12,#15181f);
  color:#fff;border-radius:24px;padding:36px 28px;margin-top:24px;
  position:relative;overflow:hidden;
}
.career::before{
  content:"";position:absolute;inset:0;
  background:
    radial-gradient(500px 200px at 0% 0%, rgba(255,59,83,.2), transparent 60%),
    radial-gradient(500px 200px at 100% 100%, rgba(31,111,235,.2), transparent 60%);
  pointer-events:none;
}
.career .section-head h2,
.career .section-head .sub{color:#fff}
.career .section-head .sub{color:#cfd3da}
.career .more{color:#ff8b00}

.career .row .rank-card{
  background:#171a20;border-color:#262a33;color:#fff;
}
.career .row .rank-card h3{color:#fff}
.career .row .rank-card .meta{color:#aab0bb}
.career .row .rank-card .meta b{color:#fff}
.career .row .rank-card .progress{background:#262a33}
.career .row .rank-card .start{background:rgba(255,139,0,.12);color:#ff8b00}
.career .row .rank-card:hover .start{background:#ff8b00;color:#0b0d12}
.career .rank-num{-webkit-text-stroke:2px #ffffff22;color:transparent}

/* ---------- Features strip ---------- */
.features{
  display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-top:24px;
}
@media (max-width:880px){.features{grid-template-columns:repeat(2,1fr)}}
.feat{
  background:var(--bg-soft);border-radius:var(--radius);
  padding:22px;display:flex;gap:14px;align-items:flex-start;
  transition:transform .25s ease;
}
.feat:hover{transform:translateY(-3px)}
.feat .ic{
  width:42px;height:42px;border-radius:12px;flex-shrink:0;
  background:#fff;display:grid;place-items:center;font-size:20px;
  box-shadow:var(--shadow-sm);
}
.feat h4{margin:0 0 4px;font-size:15px;font-weight:800}
.feat p{margin:0;font-size:13px;color:var(--ink-2)}

/* ---------- CTA banner ---------- */
.cta{
  margin:48px auto 0;max-width:1280px;padding:0 20px;
}
.cta-inner{
  background:
    radial-gradient(400px 200px at 90% 100%, rgba(255,255,255,.18), transparent 60%),
    linear-gradient(135deg,#ff3b53,#ff8b00 70%, #ffb400);
  border-radius:24px;
  color:#fff;padding:38px 32px;
  display:flex;align-items:center;justify-content:space-between;gap:24px;flex-wrap:wrap;
  position:relative;overflow:hidden;
}
.cta-inner::after{
  content:"";position:absolute;right:-40px;bottom:-40px;
  width:200px;height:200px;border-radius:999px;background:rgba(255,255,255,.12);
  animation:floatBlob 7s ease-in-out infinite;
}
@keyframes floatBlob{0%,100%{transform:translate(0,0)}50%{transform:translate(-20px,-15px) scale(1.1)}}
.cta h3{font-size:clamp(22px,3vw,30px);font-weight:900;margin:0 0 6px}
