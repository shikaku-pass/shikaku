function renderHome(){
  const hist=gH();
  const {days,streak}=getStreak();

  // Streak
  const swrap=document.getElementById("streak-wrap");
  if(hist.length&&streak>=1){
    swrap.style.display="block";
    document.getElementById("s-ico").textContent=streak>=7?"🏆":"🔥";
    document.getElementById("s-main").textContent=`🔥 ${streak}日連続学習中！`;
    document.getElementById("s-sub").textContent="継続は力なり。今日も1問から始めよう";
    const week=["月","火","水","木","金","土","日"];
    const today=new Date();
    document.getElementById("s-dots").innerHTML=week.map((d,i)=>{
      const dt=new Date(today);dt.setDate(today.getDate()-((today.getDay()||7)-1-i));
      const done=days.includes(dt.toDateString());
      const isT=dt.toDateString()===today.toDateString();
      return`<div class="sd ${done?"done":""} ${isT&&!done?"today":""}">${d}</div>`;
    }).join("");
    document.getElementById("hd-streak").style.display="flex";
    document.getElementById("hd-streak-num").textContent=`${streak}日`;
  }

  // Resume
  const rsec=document.getElementById("rsec");
  if(hist.length){
    rsec.style.display="block";
    const items=hist.map(id=>S.find(s=>s.id===id)).filter(Boolean);
    document.getElementById("rscroll").innerHTML=items.map(s=>{
      const p=gP(s);
      return`<div class="rcrd" onclick="go('${s.id}','${s.url}')">
        <div class="rcrd-top"><div class="rcrd-ico" style="background:${s.bg}">${s.ico}</div><div class="rcrd-name">${s.name}</div></div>
        <div class="rcrd-bar"><div class="rcrd-fill" style="width:${p?p.rate:0}%"></div></div>
        <div class="rcrd-meta">${p?`正答率 ${p.rate}%`:"タップして開始"}</div>
      </div>`;
    }).join("");
  }

  // Category chips
  document.getElementById("home-cats").innerHTML=CATS.map(c=>{
    const cnt=c.id==="all"?S.length:S.filter(s=>s.cat===c.id).length;
    return`<button class="chip" onclick="openCatDrawer('${c.id}')"><span class="ic">${c.ico}</span>${c.lbl}<span class="cnt">${cnt}</span></button>`;
  }).join("");

  // Purpose tiles
  document.getElementById("purpose-tiles").innerHTML=PURPS.map(p=>{
    const cnt=S.filter(p.filter).length;
    return`<div class="tile ${p.cls}" onclick="openDr('${p.id}')">
      <div class="t-ico">${p.ico}</div>
      <div><div class="t-num">${cnt}</div><div class="t-lbl">${p.name}</div></div>
    </div>`;
  }).join("");

  // Popular ranking row (Netflix)
  const topS=[...S].sort((a,b)=>a.pop-b.pop).slice(0,8);
  document.getElementById("row1").innerHTML=topS.map((s,i)=>rankCard(s,i)).join("");

  // Beginner Amazon cards (top4 dif===1)
  const beginners=[...S].filter(s=>s.dif===1).sort((a,b)=>a.pop-b.pop).slice(0,4);
  document.getElementById("home-cards").innerHTML=beginners.map(s=>amazonCard(s)).join("");

  // Career row (dark)
  const salaryS=[...S].filter(s=>s.sal>=25).sort((a,b)=>b.sal-a.sal).slice(0,6);
  document.getElementById("row2").innerHTML=salaryS.map((s,i)=>rankCard(s,i,true)).join("");

  // Reveal
  requestAnimationFrame(()=>{
    document.querySelectorAll(".reveal").forEach(el=>io.observe(el));
  });
}

/* ════════ LIST ════════ */
function renderList(){
  document.getElementById("list-cats").innerHTML=CATS.map(c=>{
    const cnt=c.id==="all"?S.length:S.filter(s=>s.cat===c.id).length;
    return`<button class="chip ${c.id===cListCat?"on":""}" onclick="swListCat('${c.id}')"><span class="ic">${c.ico}</span>${c.lbl}<span class="cnt">${cnt}</span></button>`;
  }).join("");
  const list=cListCat==="all"?S:S.filter(s=>s.cat===cListCat);
  document.getElementById("list-count").textContent=`${list.length}資格`;
  document.getElementById("sgrid").innerHTML=list.map(s=>scCard(s)).join("");
}
function swListCat(id){cListCat=id;renderList()}

/* ════════ RANK ════════ */
function renderRank(){
  document.getElementById("rtabs").innerHTML=RTYPES.map(r=>`
    <button class="rtab ${r.id===cRank?"on":""}" onclick="swRank('${r.id}')">${r.lbl}</button>`).join("");
  const rt=RTYPES.find(r=>r.id===cRank);
  const items=[...S].sort(rt.sort).slice(0,20);
  document.getElementById("rlist").innerHTML=items.map((s,i)=>{
    const p=gP(s);
    const prog=p?`<div class="sc-right"><div class="sc-prog-bar"><div class="sc-prog-fill" style="width:${p.rate}%"></div></div><div class="sc-prog-txt">${p.rate}%</div></div>`:`<div class="sc-right"><div class="sc-arr">›</div></div>`;
    return`<div class="sc" onclick="go('${s.id}','${s.url}')">
      <div style="font-size:14px;font-weight:900;min-width:24px;text-align:center;flex-shrink:0;color:${i<3?["#d4a017","#94a3b8","#b45309"][i]:""}">${i+1}</div>
      <div class="sc-ico" style="background:${s.bg}">${s.ico}</div>
      <div class="sc-body">
        <div class="sc-top"><span class="sc-name">${s.name}</span><div class="sc-tags">${tH(s.tags)}</div></div>
        <div class="sc-meta"><span>${rt.meta(s)}</span></div>
      </div>${prog}</div>`;
  }).join("");
}
function swRank(id){cRank=id;renderRank()}

/* ════════ MY ════════ */
function renderMy(){
  const hist=gH();
  const {streak}=getStreak();
  const studied=hist.map(id=>S.find(s=>s.id===id)).filter(Boolean);
  document.getElementById("my-greeting").textContent=streak>=7?"🏆 すごい継続力！":streak>=3?`🔥 ${streak}日連続中`:studied.length?"📖 学習中":"これから始めよう";
  document.getElementById("my-streak").textContent=streak;
  let totalAns=0,totalOk=0,cnt=0;
  studied.forEach(s=>{const p=gP(s);if(p){totalAns+=p.ans;totalOk+=Math.round(p.ans*p.rate/100);cnt++;}});
  document.getElementById("my-total").textContent=totalAns.toLocaleString();
  document.getElementById("my-rate").textContent=cnt?Math.round(totalOk/totalAns*100)+"%":"—";
  const grid=document.getElementById("my-icon-grid");
  const dc=document.getElementById("my-detail-card");
  const countEl=document.getElementById("my-studied-count");
  if(!studied.length){
    countEl.textContent="";
    grid.innerHTML=`<div class="empty" style="grid-column:1/-1"><div class="empty-ico">📚</div><div class="empty-msg">まだ学習した資格がありません</div><div class="empty-sub">ホームから好きな資格を選ぼう！</div></div>`;
    dc.style.display="none";
  } else {
    countEl.textContent=`${studied.length}資格`;
    grid.className="my-icon-grid";
    grid.innerHTML=studied.map(s=>{
      const p=gP(s);
      return`<div class="mig-item ${s.id===myActiveId?"active":""}" onclick="toggleDetail('${s.id}')" id="mig-${s.id}">
        ${p?`<div class="mig-badge">${p.rate}%</div>`:""}
        <div class="mig-ico" style="background:${s.bg}">${s.ico}</div>
        <div class="mig-name">${s.name}</div>
      </div>`;
    }).join("");
    if(myActiveId&&studied.find(s=>s.id===myActiveId)) renderDetailCard(myActiveId);
    else dc.style.display="none";
  }
  document.getElementById("my-menu").innerHTML=[
    {ico:"🔔",name:"学習リマインダー",sub:"毎日の学習通知を設定",fn:"alert('現在準備中です')"},
    {ico:"🗑️",name:"学習履歴をリセット",sub:"進捗・履歴を全て削除",fn:"resetAll()"},
    {ico:"📤",name:"このサービスをシェア",sub:"友だちにも広めよう",fn:"shareApp()"},
    {ico:"ℹ️",name:"資格Passについて",sub:"サービス概要・お問い合わせ",fn:"location.href='about.html'"},
  ].map(m=>`<div class="my-item" onclick="${m.fn}">
    <div class="my-item-ico">${m.ico}</div>
    <div class="my-item-body"><div class="my-item-name">${m.name}</div><div class="my-item-sub">${m.sub}</div></div>
    <div class="my-item-arr">›</div>
  </div>`).join("");
}

function toggleDetail(id){
  if(myActiveId===id){
    myActiveId=null;
    document.querySelectorAll(".mig-item").forEach(el=>el.classList.remove("active"));
    document.getElementById("my-detail-card").style.display="none";
    return;
  }
  myActiveId=id;
  document.querySelectorAll(".mig-item").forEach(el=>el.classList.remove("active"));
  const el=document.getElementById("mig-"+id);
  if(el) el.classList.add("active");
  renderDetailCard(id);
  setTimeout(()=>{const dc=document.getElementById("my-detail-card");if(dc)dc.scrollIntoView({behavior:"smooth",block:"nearest"})},50);
}

function renderDetailCard(id){
  const s=S.find(x=>x.id===id);
  const p=gP(s);
  const dc=document.getElementById("my-detail-card");
  dc.style.display="block";
  const rate=p?p.rate:0,ans=p?p.ans:0,correct=p?Math.round(ans*rate/100):0;
  dc.innerHTML=`<div class="detail-card">
    <div class="dc-head">
      <div class="dc-ico" style="background:${s.bg}">${s.ico}</div>
      <div class="dc-name">${s.name}</div>
      <div class="dc-close" onclick="toggleDetail('${id}')">✕</div>
    </div>
    <div class="dc-stats">
      <div class="dc-stat"><div class="dc-stat-n">${ans.toLocaleString()}</div><div class="dc-stat-l">解答数</div></div>
      <div class="dc-stat"><div class="dc-stat-n" style="color:var(--green)">${correct.toLocaleString()}</div><div class="dc-stat-l">正解数</div></div>
      <div class="dc-stat"><div class="dc-stat-n" style="color:#E53935">${(ans-correct).toLocaleString()}</div><div class="dc-stat-l">不正解数</div></div>
    </div>
    <div class="dc-bar-wrap">
      <div class="dc-bar-lbl"><span>正答率</span><span style="font-weight:700;color:${rate>=70?"var(--green)":"var(--gold)"}">${rate}%</span></div>
      <div class="dc-bar"><div class="dc-bar-fill" style="width:${rate}%;background:${rate>=70?"var(--green)":"var(--gold)"}"></div></div>
    </div>
    <div class="dc-actions">
      <button class="dc-btn-primary" onclick="go('${s.id}','${s.url}')">🎯 続きから学習</button>
      <button class="dc-btn-ghost" onclick="toggleDetail('${id}')">閉じる</button>
    </div>
  </div>`;
}

/* ════════ SEARCH ════════ */
function openSearch(){
  document.getElementById("searchModal").classList.add("on");
  setTimeout(()=>document.getElementById("sm-input").focus(),100);
  document.getElementById("sm-tags").innerHTML=CATS.slice(1).map(c=>`<button class="sm-tag" onclick="searchCat('${c.id}')">${c.ico} ${c.lbl}</button>`).join("");
  document.getElementById("sm-popular").innerHTML=[...S].sort((a,b)=>a.pop-b.pop).slice(0,5).map(s=>smItem(s)).join("");
}
function closeSearch(){
  document.getElementById("searchModal").classList.remove("on");
  document.getElementById("sm-input").value="";
  document.getElementById("sm-quick").style.display="block";
  document.getElementById("sm-results-wrap").style.display="none";
}
function searchCat(cat){
  document.getElementById("sm-input").value=CATS.find(c=>c.id===cat)?.lbl||"";
  showResults(S.filter(s=>s.cat===cat),CATS.find(c=>c.id===cat)?.lbl||"");
}
function doSearch(q){
  if(!q.trim()){document.getElementById("sm-quick").style.display="block";document.getElementById("sm-results-wrap").style.display="none";return}
  document.getElementById("sm-quick").style.display="none";document.getElementById("sm-results-wrap").style.display="block";
  const kw=q.trim().toLowerCase();
  showResults(S.filter(s=>s.name.toLowerCase().includes(kw)),`「${q}」`);
}
function showResults(r,label){
  document.getElementById("sm-count").textContent=`${label}の検索結果 ${r.length}件`;
  document.getElementById("sm-results").innerHTML=r.length?r.map(s=>smItem(s)).join(""):`<div class="empty"><div class="empty-ico">🔍</div><div class="empty-msg">見つかりませんでした</div></div>`;
}
function smItem(s){
  const p=gP(s);
  return`<div class="sm-result" onclick="closeSearch();go('${s.id}','${s.url}')">
    <div class="sm-result-ico" style="background:${s.bg}">${s.ico}</div>
    <div style="flex:1;min-width:0"><div class="sm-result-name">${s.name}</div><div class="sm-result-meta">合格率 ${s.rate}% · ${s.h}${p?` · 正答率 ${p.rate}%`:""}</div></div>
    <div class="sm-result-arr">›</div>
  </div>`;
}

/* ════════ DRAWERS ════════ */
function openCatDrawer(catId){
  const cat=CATS.find(c=>c.id===catId);
  const items=catId==="all"?S:S.filter(s=>s.cat===catId);
  showDrawer(cat.ico,cat.lbl,`${items.length}資格`,items);
}
function openDr(pid){
  const purp=PURPS.find(p=>p.id===pid)||{ico:"📋",name:pid,filter:()=>true};
  const items=S.filter(purp.filter).sort((a,b)=>a.pop-b.pop);
  showDrawer(purp.ico,purp.name,`${items.length}資格`,items);
}
function showDrawer(ico,ttl,sub,items){
  document.getElementById("dr-ico").textContent=ico;
  document.getElementById("dr-ttl").textContent=ttl;
  document.getElementById("dr-sub").textContent=sub+" — タップして学習開始";
  document.getElementById("dr-list").innerHTML=items.map(s=>{
    const p=gP(s);
    return`<div class="di" onclick="closeDr();setTimeout(()=>go('${s.id}','${s.url}'),180)">
      <div class="di-ico" style="background:${s.bg}">${s.ico}</div>
      <div class="di-body"><div class="di-name">${s.name}</div><div class="di-meta">合格率 ${s.rate}% · ${str(s.dif)} · ${s.h}</div></div>
      ${p?`<div class="di-prog">${p.rate}%`:""}${p?"</div>":""}
      <div class="di-arr">›</div>
    </div>`;
  }).join("");
  document.getElementById("ov").classList.add("on");
  document.getElementById("dr").classList.add("on");
  document.body.style.overflow="hidden";
}
function closeDr(){
  document.getElementById("ov").classList.remove("on");
  document.getElementById("dr").classList.remove("on");
  document.body.style.overflow="";
}

/* ════════ MISC ════════ */
function clearHist(){
  if(confirm("学習履歴を消去しますか？")){localStorage.removeItem(HK);document.getElementById("rsec").style.display="none";document.getElementById("streak-wrap").style.display="none";renderHome();}
}
function resetAll(){
  if(confirm("全ての学習データをリセットしますか？\nこの操作は取り消せません。")){
    const keys=[];for(let i=0;i<localStorage.length;i++)keys.push(localStorage.key(i));
    keys.forEach(k=>{if(k.startsWith("dojo_")||k===HK||k===SK)localStorage.removeItem(k);});
    alert("リセット完了しました。");renderHome();renderMy();
  }
}
function shareApp(){
  const url="https://shikaku-drill.jp/";
  if(navigator.share){navigator.share({title:"資格ドリル",text:"無料4択問題集！59資格対応",url});}
  else{navigator.clipboard.writeText(url).then(()=>alert("URLをコピーしました"));}
}

/* ════════ START DRILL ════════ */
function startDrill(){
  const hist=gH();
  if(hist.length){
    // 直近の学習履歴がある → 続きから選択モーダルを表示
    showResumeModal();
  } else {
    // 履歴なし → 一覧へ
    switchTab('list');
  }
}

/* 「続きから or 新しく始める」モーダル */
function showResumeModal(){
  const hist=gH();
  const items=hist.map(id=>S.find(s=>s.id===id)).filter(Boolean).slice(0,5);
  // モーダル要素生成（なければ追加）
  let modal=document.getElementById("resume-modal");
  if(!modal){
    modal=document.createElement("div");
    modal.id="resume-modal";
    modal.style.cssText="display:none;position:fixed;inset:0;z-index:500;background:rgba(0,0,0,.55);backdrop-filter:blur(4px);align-items:flex-end;justify-content:center";
    modal.innerHTML=`<div id="resume-sheet" style="background:var(--bg2);border-radius:22px 22px 0 0;width:100%;max-width:520px;padding:20px 16px 32px;transform:translateY(100%);transition:transform .35s cubic-bezier(.16,1,.3,1)">
      <div style="width:32px;height:3px;background:var(--border);border-radius:2px;margin:0 auto 16px"></div>
      <div style="font-size:16px;font-weight:900;margin-bottom:4px">▶ どこから始めますか？</div>
      <div style="font-size:12px;color:var(--text3);margin-bottom:16px">前回の学習の続きから、またはカテゴリを選んで新しく始められます</div>
      <div style="font-size:11px;font-weight:700;color:var(--text3);letter-spacing:1.5px;text-transform:uppercase;margin-bottom:8px">🕐 前回の学習</div>
      <div id="resume-modal-list"></div>
      <button onclick="closeResumeModal();switchTab('list')" style="width:100%;margin-top:12px;padding:13px;border-radius:12px;border:1.5px solid var(--border);background:var(--bg);font-size:14px;font-weight:700;color:var(--text2);cursor:pointer;transition:all .15s" onmouseover="this.style.borderColor='var(--brand)';this.style.color='var(--brand)'" onmouseout="this.style.borderColor='var(--border)';this.style.color='var(--text2)'">📋 資格一覧から選ぶ</button>
    </div>`;
    modal.addEventListener("click",e=>{if(e.target===modal)closeResumeModal();});
    document.body.appendChild(modal);
  }
  // リスト更新
  document.getElementById("resume-modal-list").innerHTML=items.map(s=>{
    const p=gP(s);
    return`<div onclick="closeResumeModal();go('${s.id}','${s.url}')" style="display:flex;align-items:center;gap:10px;padding:10px 12px;border:1.5px solid var(--border);border-radius:12px;margin-bottom:7px;cursor:pointer;transition:all .15s;background:var(--bg2)" onmouseover="this.style.borderColor='var(--brand)';this.style.background='#fff5f6'" onmouseout="this.style.borderColor='var(--border)';this.style.background='var(--bg2)'">
      <div style="width:38px;height:38px;border-radius:10px;background:${s.bg};display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0">${s.ico}</div>
      <div style="flex:1;min-width:0">
        <div style="font-size:13px;font-weight:700;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${s.name}</div>
        <div style="font-size:10px;color:var(--text3);margin-top:2px">${p?`正答率 ${p.rate}% · ${p.ans}問解答済み`:`合格率 ${s.rate}% · ${s.h}`}</div>
      </div>
      ${p?`<div style="min-width:36px;text-align:right"><div style="height:4px;width:36px;background:var(--bg);border-radius:2px;overflow:hidden;margin-bottom:3px"><div style="height:100%;width:${p.rate}%;background:var(--green);border-radius:2px"></div></div><div style="font-size:9px;color:var(--green);font-weight:700">${p.rate}%</div></div>`:""}
      <div style="color:#ccc;font-size:16px">›</div>
    </div>`;
  }).join("");
  modal.style.display="flex";
  requestAnimationFrame(()=>{requestAnimationFrame(()=>{document.getElementById("resume-sheet").style.transform="translateY(0)";});});
}

function closeResumeModal(){
  const modal=document.getElementById("resume-modal");
  const sheet=document.getElementById("resume-sheet");
  if(!modal) return;
  sheet.style.transform="translateY(100%)";
  setTimeout(()=>{modal.style.display="none";},350);
}

/* ════════ ROW SCROLL BUTTONS ════════ */
document.querySelectorAll(".row-btn").forEach(btn=>{
  btn.addEventListener("click",()=>{
    const row=document.getElementById(btn.dataset.target);
    if(!row) return;
    const dir=btn.classList.contains("left")?-1:1;
    row.scrollBy({left:dir*row.clientWidth*.85,behavior:"smooth"});
  });
});

/* ════════ REVEAL on SCROLL ════════ */
const io=new IntersectionObserver(entries=>{
  entries.forEach(e=>{if(e.isIntersecting){e.target.classList.add("in");io.unobserve(e.target);}});
},{threshold:.1});

/* ════════ INIT ════════ */
renderHome();
</script>

</body>
</html>