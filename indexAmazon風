function scCard(s){
  const p=gP(s);
  const prog=p
    ?`<div class="sc-right"><div class="sc-prog-bar"><div class="sc-prog-fill" style="width:${p.rate}%"></div></div><div class="sc-prog-txt">${p.rate}%</div></div>`
    :`<div class="sc-right"><div class="sc-arr">›</div></div>`;
  return`<div class="sc" onclick="go('${s.id}','${s.url}')">
    <div class="sc-ico" style="background:${s.bg}">${s.ico}</div>
    <div class="sc-body">
      <div class="sc-top"><span class="sc-name">${s.name}</span><div class="sc-tags">${tH(s.tags)}</div></div>
      <div class="sc-meta"><span>合格率${s.rate}%</span><span>${s.h}</span><span>${str(s.dif)}</span></div>
    </div>${prog}</div>`;
}

function rankCard(s,i,dark=false){
  const p=gP(s);
  const cl=nc(i);
  const crown=cl?`<div class="rk-crown">${i===0?"👑":i===1?"🥈":"🥉"}</div>`:"";
  const prog=p?p.rate:Math.floor(Math.random()*30+50);
  return`<article class="rank-card ${cl}" onclick="go('${s.id}','${s.url}')">
    <div class="rk-num">${i+1}</div>${crown}
    <h3>${s.name}</h3>
    <div class="rk-stars">${stars(s.dif)}</div>
    <div class="rk-meta"><span>合格率 <b>${s.rate}%</b></span><span>${s.h}</span></div>
    <div class="rk-progress"><i style="width:${prog}%"></i></div>
    <div class="rk-prog-lbl">${p?"正答率 "+p.rate+"%":"受験者の人気度"}</div>
    <div class="rk-start">▶ 問題を解く<span>${s.q}問</span></div>
  </article>`;
}

function amazonCard(s){
  const bg=BGMAP[s.cat]||"bg-it";
