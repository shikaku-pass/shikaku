<!DOCTYPE html>

<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>資格ドリル — 無料4択問題集 59資格対応</title>
<meta name="description" content="ITパスポート・宅建・FP・簿記・危険物など人気資格の無料4択問題集。59資格対応。登録不要・完全無料。">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700;900&family=Inter:wght@700;900&display=swap" rel="stylesheet">
<style>
:root{
  --navy:#0f1623;--navy2:#171e2e;--navy3:#1e2840;
  --green:#1D9E75;--green-d:#0F6E56;--green-bg:#E1F5EE;
  --brand:#ff3b53;--brand2:#ff7a3d;--gold:#ffb400;
  --bg:#f5f4f0;--bg2:#fff;--border:#e5e3dc;
  --text:#1a1a1a;--text2:#555;--text3:#999;
  --radius:14px;--radius-s:10px;--tap:52px;
  --shadow:0 2px 8px rgba(0,0,0,.08);
  --shadow-md:0 8px 24px rgba(0,0,0,.12);
  --shadow-lg:0 20px 50px rgba(0,0,0,.18);
  --bnav:60px;
}
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
html{scroll-behavior:smooth}
body{font-family:"Noto Sans JP",sans-serif;background:var(--bg);color:var(--text);padding-bottom:var(--bnav)}
a{text-decoration:none;color:inherit}
button{font-family:inherit;cursor:pointer;border:none;background:none}

/* ── HEADER ── */
.hd{background:var(–navy);height:56px;display:flex;align-items:center;padding:0 16px;position:sticky;top:0;z-index:200;border-bottom:1px solid rgba(255,255,255,.06)}
.hd-inner{display:flex;align-items:center;justify-content:space-between;width:100%;gap:12px}
.logo{color:#fff;font-size:18px;font-weight:900;letter-spacing:-.5px;display:flex;align-items:center;gap:8px;flex-shrink:0;font-family:“Inter”,“Noto Sans JP”}
.logo-mark{width:32px;height:32px;border-radius:10px;background:linear-gradient(135deg,var(–brand),var(–brand2));display:grid;place-items:center;font-size:15px;color:#fff;font-weight:900;box-shadow:0 4px 14px rgba(255,59,83,.45);animation:pulse 2.8s ease-in-out infinite;flex-shrink:0}
@keyframes pulse{0%,100%{box-shadow:0 4px 14px rgba(255,59,83,.45)}50%{box-shadow:0 6px 22px rgba(255,106,61,.65)}}
.logo-text{background:linear-gradient(90deg,#fff,#ffd6c2);-webkit-background-clip:text;background-clip:text;color:transparent}
.hd-right{display:flex;align-items:center;gap:10px}
.hd-streak{display:flex;align-items:center;gap:4px;background:rgba(255,255,255,.1);border-radius:20px;padding:4px 10px}
.hd-streak-num{color:#fff;font-size:12px;font-weight:700}

/* ── SEARCH BAR ── */
.search-wrap{background:var(–navy);padding:0 16px 12px}
.search-bar{background:rgba(255,255,255,.12);border:1px solid rgba(255,255,255,.18);border-radius:999px;display:flex;align-items:center;gap:8px;padding:0 14px;height:42px;cursor:pointer;transition:all .2s}
.search-bar:hover{background:rgba(255,255,255,.18);border-color:rgba(255,255,255,.3)}
.search-icon{font-size:15px;opacity:.7}
.search-placeholder{color:rgba(255,255,255,.5);font-size:13px;flex:1}
.search-kbd{font-size:10px;color:rgba(255,255,255,.3);background:rgba(255,255,255,.1);padding:2px 7px;border-radius:5px}

/* ── SUBNAV ── */
.subnav{background:var(–navy2);border-bottom:1px solid rgba(255,255,255,.06);position:sticky;top:56px;z-index:100;overflow-x:auto;scrollbar-width:none}
.subnav::-webkit-scrollbar{display:none}
.subnav-inner{display:flex;min-width:max-content;padding:0 8px}
.sn{flex-shrink:0;padding:10px 14px;font-size:13px;font-weight:700;color:rgba(255,255,255,.45);border-bottom:2px solid transparent;cursor:pointer;white-space:nowrap;transition:all .15s}
.sn:hover{color:rgba(255,255,255,.8)}
.sn.on{color:#fff;border-bottom-color:var(–brand)}
.sn.live{color:var(–brand2)}
.sn.live::before{content:“●”;margin-right:5px;color:var(–brand);animation:blink 1.4s infinite}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.3}}

/* ── PAGE ── */
.page{display:none}.page.on{display:block}
.page-wrap{max-width:960px;margin:0 auto}

/* ── HERO ── */
.hero{background:radial-gradient(1000px 400px at 15% -5%,rgba(255,59,83,.2),transparent 60%),radial-gradient(800px 400px at 90% 0%,rgba(29,158,117,.15),transparent 60%),linear-gradient(180deg,var(–navy) 0%,var(–navy2) 100%);color:#fff;padding:40px 16px 52px}
.hero h1{font-size:clamp(26px,5vw,42px);line-height:1.15;font-weight:900;margin-bottom:14px;letter-spacing:-.5px;font-family:“Inter”,“Noto Sans JP”}
.hero h1 .accent{background:linear-gradient(90deg,var(–brand),var(–brand2) 60%,var(–gold));-webkit-background-clip:text;background-clip:text;color:transparent}
.hero p{font-size:14px;color:rgba(255,255,255,.65);margin-bottom:20px;line-height:1.7}
.hero-cta{display:flex;gap:10px;flex-wrap:wrap}
.btn{display:inline-flex;align-items:center;gap:8px;padding:12px 20px;border-radius:999px;font-weight:700;font-size:14px;transition:transform .2s,box-shadow .25s,filter .2s}
.btn-primary{background:linear-gradient(135deg,var(–brand),var(–brand2));color:#fff;box-shadow:0 8px 22px rgba(255,59,83,.35)}
.btn-primary:hover{transform:translateY(-2px);box-shadow:0 12px 28px rgba(255,59,83,.5)}
.btn-ghost{background:rgba(255,255,255,.1);color:#fff;backdrop-filter:blur(6px)}
.btn-ghost:hover{background:rgba(255,255,255,.18)}
.hero-badges{display:flex;gap:8px;margin-top:20px;flex-wrap:wrap}
.badge{background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.12);padding:6px 12px;border-radius:999px;font-size:12px;color:rgba(255,255,255,.8);display:inline-flex;align-items:center;gap:6px}
.badge .dot{width:6px;height:6px;border-radius:50%;background:#22c55e;box-shadow:0 0 0 3px rgba(34,197,94,.25)}

/* ── SEC ── */
.sec{padding:20px 16px 0}
.sec:last-child{padding-bottom:24px}
.sec-hd{display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:12px}
.sec-ttl{font-size:16px;font-weight:900;letter-spacing:-.3px;display:flex;align-items:center;gap:6px}
.sec-ttl::before{content:””;width:3px;height:16px;background:linear-gradient(var(–brand),var(–brand2));border-radius:2px;flex-shrink:0}
.sec-sub{font-size:11px;color:var(–text3);margin-top:2px}
.sec-more{font-size:12px;color:var(–brand2);font-weight:700}

/* ── CATEGORY CHIPS ── */
.chips{display:flex;gap:8px;overflow-x:auto;scrollbar-width:none;padding-bottom:4px}
.chips::-webkit-scrollbar{display:none}
.chip{flex:0 0 auto;display:inline-flex;align-items:center;gap:6px;padding:8px 14px;border-radius:999px;background:var(–bg2);color:var(–text);font-size:13px;font-weight:700;border:1.5px solid var(–border);transition:all .2s;cursor:pointer}
.chip .ic{font-size:15px}
.chip .cnt{background:var(–bg);color:var(–text3);font-size:10px;font-weight:700;padding:1px 6px;border-radius:999px;border:1px solid var(–border)}
.chip:hover{background:#fff5f6;border-color:var(–brand);color:var(–brand);transform:translateY(-2px)}
.chip.on{background:var(–text);color:#fff;border-color:var(–text)}
.chip.on .cnt{background:#2a2c33;color:#fff;border-color:#2a2c33}

/* ── PURPOSE TILES ── */
.tiles{display:grid;grid-template-columns:repeat(3,1fr);gap:10px}
.tile{position:relative;overflow:hidden;border-radius:var(–radius);padding:18px 14px 14px;color:#fff;font-weight:800;display:flex;flex-direction:column;justify-content:space-between;min-height:110px;transition:transform .3s,box-shadow .3s;cursor:pointer;box-shadow:var(–shadow)}
.tile:hover{transform:translateY(-4px);box-shadow:var(–shadow-md)}
.tile::after{content:””;position:absolute;inset:0;background:radial-gradient(100px 60px at 100% 0%,rgba(255,255,255,.25),transparent 70%);pointer-events:none}
.tile .t-ico{font-size:24px;margin-bottom:6px}
.tile .t-num{font-size:20px;font-weight:900;font-family:“Inter”,“Noto Sans JP”;line-height:1}
.tile .t-lbl{font-size:12px;opacity:.9;margin-top:2px}
.t1{background:linear-gradient(135deg,#ff3b53,#ff8b00)}
.t2{background:linear-gradient(135deg,#1D9E75,#22d3ee)}
.t3{background:linear-gradient(135deg,#8b5cf6,#ec4899)}
.t4{background:linear-gradient(135deg,#0ea5e9,#1e40af)}
.t5{background:linear-gradient(135deg,#22c55e,#84cc16)}
.t6{background:linear-gradient(135deg,#f97316,#ef4444)}

/* ── RANKING ROW (Netflix-style horizontal) ── */
.row-wrap{position:relative;margin:0 -16px;padding:0 16px}
.row{display:flex;gap:12px;overflow-x:auto;padding:4px 4px 16px;scroll-snap-type:x mandatory;scrollbar-width:none}
.row::-webkit-scrollbar{display:none}
.row>*{scroll-snap-align:start}
.row-btn{position:absolute;top:50%;transform:translateY(-50%);width:38px;height:38px;border-radius:50%;background:#fff;box-shadow:var(–shadow-md);display:grid;place-items:center;font-size:16px;font-weight:900;color:var(–text);z-index:5;border:1px solid var(–border);opacity:0;transition:opacity .2s,transform .2s;cursor:pointer}
.row-wrap:hover .row-btn{opacity:1}
.row-btn:hover{transform:translateY(-50%) scale(1.1)}
.row-btn.left{left:4px}.row-btn.right{right:4px}

/* ── RANK CARD (Netflix-style) ── */
.rank-card{flex:0 0 260px;position:relative;background:var(–bg2);border-radius:var(–radius);border:1px solid var(–border);padding:16px 16px 16px 68px;transition:transform .3s,box-shadow .3s,border-color .3s;overflow:hidden;cursor:pointer}
.rank-card:hover{transform:translateY(-4px) scale(1.01);box-shadow:var(–shadow-md);border-color:transparent}
.rk-num{position:absolute;left:-5px;top:10px;font-family:“Inter”;font-weight:900;font-size:72px;line-height:.9;letter-spacing:-5px;color:transparent;-webkit-text-stroke:2px var(–text);pointer-events:none;opacity:.12}
.rank-card.gold .rk-num{-webkit-text-stroke:2px #d4a017;opacity:.2}
.rank-card.silver .rk-num{-webkit-text-stroke:2px #94a3b8;opacity:.2}
.rank-card.bronze .rk-num{-webkit-text-stroke:2px #b45309;opacity:.2}
.rk-crown{position:absolute;top:12px;right:12px;width:26px;height:26px;border-radius:7px;display:grid;place-items:center;font-size:13px;color:#fff}
.gold .rk-crown{background:linear-gradient(135deg,#f7c948,#d4a017)}
.silver .rk-crown{background:linear-gradient(135deg,#cbd5e1,#94a3b8)}
.bronze .rk-crown{background:linear-gradient(135deg,#fbbf24,#b45309)}
.rank-card h3{font-size:14px;margin-bottom:6px;font-weight:800;line-height:1.3}
.rk-stars{color:var(–gold);font-size:12px;letter-spacing:.5px}
.rk-stars .off{color:#e0e3ea}
.rk-meta{display:flex;gap:10px;color:var(–text2);font-size:11px;margin:6px 0 8px;flex-wrap:wrap}
.rk-meta b{color:var(–text)}
.rk-progress{height:4px;background:var(–bg);border-radius:99px;overflow:hidden;margin:6px 0 4px}
.rk-progress i{display:block;height:100%;background:linear-gradient(90deg,var(–brand),var(–brand2));border-radius:99px}
.rk-prog-lbl{font-size:10px;color:var(–text3)}
.rk-start{margin-top:10px;display:flex;align-items:center;justify-content:space-between;padding:8px 12px;border-radius:8px;background:#fff5f6;color:var(–brand);font-weight:700;font-size:12px;transition:background .2s,color .2s}
.rank-card:hover .rk-start{background:var(–brand);color:#fff}

/* ── CAREER ROW (dark Netflix-style) ── */
.career{background:linear-gradient(180deg,var(–navy),var(–navy2));border-radius:20px;padding:24px 16px;margin:0 0 0;position:relative;overflow:hidden}
.career::before{content:””;position:absolute;inset:0;background:radial-gradient(500px 200px at 0% 0%,rgba(255,59,83,.15),transparent 60%),radial-gradient(500px 200px at 100% 100%,rgba(29,158,117,.15),transparent 60%);pointer-events:none}
.career .sec-ttl{color:#fff}
.career .sec-sub{color:rgba(255,255,255,.5)}
.career .sec-more{color:var(–brand2)}
.career .rank-card{background:rgba(255,255,255,.06);border-color:rgba(255,255,255,.1);color:#fff}
.career .rank-card h3{color:#fff}
.career .rk-meta{color:rgba(255,255,255,.6)}
.career .rk-meta b{color:#fff}
.career .rk-progress{background:rgba(255,255,255,.1)}
.career .rk-start{background:rgba(255,139,0,.12);color:#ff8b00}
.career .rank-card:hover .rk-start{background:#ff8b00;color:var(–navy)}
.career .rk-stars .off{color:rgba(255,255,255,.2)}
.career .rk-num{-webkit-text-stroke:2px rgba(255,255,255,.15)}

/* ── AMAZON-STYLE CARDS (beginner) ── */
.cards{display:grid;grid-template-columns:repeat(2,1fr);gap:12px}
.card{background:var(–bg2);border-radius:var(–radius);border:1px solid var(–border);overflow:hidden;transition:transform .3s,box-shadow .3s;display:flex;flex-direction:column;cursor:pointer}
.card:hover{transform:translateY(-5px);box-shadow:var(–shadow-md)}
.card-thumb{height:110px;position:relative;overflow:hidden;display:grid;place-items:center;color:#fff;font-weight:900;font-size:28px;letter-spacing:-1px;font-family:“Inter”,“Noto Sans JP”}
.card-thumb::before{content:””;position:absolute;inset:0;background:radial-gradient(160px 100px at 80% 20%,rgba(255,255,255,.25),transparent 60%)}
.card-thumb .ctag{position:absolute;left:10px;top:10px;background:rgba(0,0,0,.45);backdrop-filter:blur(4px);color:#fff;font-size:10px;font-weight:700;padding:3px 7px;border-radius:6px}
.card-body{padding:12px;flex:1;display:flex;flex-direction:column}
.card-body h4{font-size:13px;font-weight:800;margin-bottom:6px;line-height:1.4}
.card-stars{color:var(–gold);font-size:11px;letter-spacing:.5px;margin-bottom:6px}
.card-stars .off{color:#e0e3ea}
.card-meta{display:flex;justify-content:space-between;color:var(–text2);font-size:11px;margin-bottom:8px}
.card-price{font-family:“Inter”;font-size:18px;font-weight:900;color:#22c55e;margin-bottom:10px}
.card-price small{font-size:11px;color:var(–text3);font-weight:500}
.card-btn{padding:9px;border-radius:8px;background:linear-gradient(180deg,#ffb400,#ff8b00);color:#1a1c20;font-weight:800;font-size:12px;text-align:center;transition:filter .2s,transform .2s;margin-top:auto}
.card:hover .card-btn{filter:brightness(1.05);transform:none}
.bg-it{background:linear-gradient(135deg,#1f6feb,#22d3ee)}
.bg-fp{background:linear-gradient(135deg,#22c55e,#84cc16)}
.bg-bk{background:linear-gradient(135deg,#8b5cf6,#ec4899)}
.bg-ai{background:linear-gradient(135deg,#ff3b53,#ff8b00)}
.bg-law{background:linear-gradient(135deg,#f59e0b,#d97706)}
.bg-re{background:linear-gradient(135deg,#0ea5e9,#1e40af)}

/* ── SC LIST ── */
.slist{display:flex;flex-direction:column;gap:6px}
.sc{background:var(–bg2);border:1px solid var(–border);border-radius:var(–radius);padding:10px 12px;display:flex;align-items:center;gap:10px;color:inherit;transition:all .15s;cursor:pointer}
.sc:hover{border-color:var(–brand);box-shadow:var(–shadow);transform:translateX(3px)}
.sc-ico{width:36px;height:36px;border-radius:9px;display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0}
.sc-body{flex:1;min-width:0}
.sc-top{display:flex;align-items:center;gap:4px;margin-bottom:3px}
.sc-name{font-size:13px;font-weight:700;flex:1;min-width:0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.sc-tags{display:flex;gap:3px;flex-shrink:0}
.sc-meta{font-size:10px;color:var(–text3);display:flex;align-items:center;gap:6px}
.sc-right{display:flex;flex-direction:column;align-items:flex-end;gap:3px;flex-shrink:0}
.sc-prog-bar{width:38px;height:3px;background:var(–bg);border-radius:2px;overflow:hidden}
.sc-prog-fill{height:100%;background:var(–green);border-radius:2px}
.sc-prog-txt{font-size:9px;color:var(–green);font-weight:700}
.sc-arr{color:#ccc;font-size:14px}

/* ── TAGS ── */
.tp{font-size:9px;padding:2px 5px;border-radius:4px;font-weight:700}
.tp-hot{background:#FCEBEB;color:#A32D2D}
.tp-pop{background:#FAEEDA;color:#633806}
.tp-new{background:#E1F5EE;color:#085041}
.tp-hard{background:#F3EBFE;color:#4a2080}

/* ── FEATURES ── */
.features{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.feat{background:var(–bg2);border-radius:var(–radius);padding:16px;display:flex;gap:12px;align-items:flex-start;border:1px solid var(–border);transition:transform .25s}
.feat:hover{transform:translateY(-3px)}
.feat-ic{width:40px;height:40px;border-radius:12px;flex-shrink:0;background:var(–bg);display:grid;place-items:center;font-size:20px;box-shadow:var(–shadow)}
.feat h4{margin:0 0 3px;font-size:13px;font-weight:800}
.feat p{margin:0;font-size:11px;color:var(–text2)}

/* ── CTA ── */
.cta-banner{background:radial-gradient(400px 200px at 90% 100%,rgba(255,255,255,.15),transparent 60%),linear-gradient(135deg,var(–brand),var(–brand2) 70%,var(–gold));border-radius:20px;color:#fff;padding:28px 20px;display:flex;align-items:center;justify-content:space-between;gap:16px;flex-wrap:wrap;position:relative;overflow:hidden;margin:0 16px}
.cta-banner::after{content:””;position:absolute;right:-30px;bottom:-30px;width:160px;height:160px;border-radius:50%;background:rgba(255,255,255,.1)}
.cta-banner h3{font-size:18px;font-weight:900;margin-bottom:4px}
.cta-banner p{font-size:12px;opacity:.9}
.cta-banner .btn{background:#fff;color:var(–brand);font-size:13px;padding:10px 18px}

/* ── STREAK ── */
.streak-card{background:linear-gradient(135deg,var(–navy),var(–navy3));border-radius:var(–radius);padding:14px 16px;display:flex;align-items:center;gap:12px;margin:16px 16px 0}
.s-ico{font-size:28px;flex-shrink:0}
.s-body{flex:1;min-width:0}
.s-main{font-size:13px;font-weight:700;color:#fff;margin-bottom:2px}
.s-sub{font-size:11px;color:rgba(255,255,255,.5)}
.s-dots{display:flex;gap:4px;margin-top:8px}
.sd{width:26px;height:26px;border-radius:7px;display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:700;border:1.5px solid rgba(255,255,255,.12);color:rgba(255,255,255,.3)}
.sd.done{background:var(–green);border-color:var(–green);color:#fff}
.sd.today{background:rgba(255,255,255,.15);border-color:rgba(255,255,255,.35);color:#fff}

/* ── RESUME ── */
.resume-scroll{display:flex;gap:8px;overflow-x:auto;scrollbar-width:none;padding-bottom:4px}
.resume-scroll::-webkit-scrollbar{display:none}
.rcrd{flex-shrink:0;width:130px;background:var(–bg2);border:1px solid var(–border);border-radius:var(–radius);padding:10px;cursor:pointer;transition:border-color .15s}
.rcrd:hover{border-color:var(–green)}
.rcrd-top{display:flex;align-items:center;gap:7px;margin-bottom:7px}
.rcrd-ico{width:26px;height:26px;border-radius:7px;display:flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0}
.rcrd-name{font-size:11px;font-weight:700;line-height:1.3;flex:1;min-width:0;overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical}
.rcrd-bar{height:3px;background:var(–bg);border-radius:2px;overflow:hidden;margin-bottom:4px}
.rcrd-fill{height:100%;background:var(–green);border-radius:2px}
.rcrd-meta{font-size:9px;color:var(–text3)}

/* ── RANK TABS ── */
.rtabs{display:flex;gap:6px;margin-bottom:10px}
.rtab{padding:6px 14px;border-radius:999px;font-size:12px;font-weight:700;cursor:pointer;border:1.5px solid var(–border);background:var(–bg2);color:var(–text3);transition:all .15s}
.rtab.on{background:var(–navy);border-color:var(–navy);color:#fff}

/* ── MY PAGE ── */
.my-hero{background:radial-gradient(600px 200px at 50% -10%,rgba(255,59,83,.15),transparent 60%),linear-gradient(180deg,var(–navy),var(–navy2));padding:24px 16px 28px}
.my-avatar{width:56px;height:56px;border-radius:50%;background:rgba(255,255,255,.1);display:flex;align-items:center;justify-content:center;font-size:26px;margin-bottom:10px}
.my-greeting{color:#fff;font-size:16px;font-weight:900;margin-bottom:3px}
.my-sub{color:rgba(255,255,255,.45);font-size:12px}
.my-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-top:14px}
.my-stat{background:rgba(255,255,255,.08);border-radius:10px;padding:10px;text-align:center;border:1px solid rgba(255,255,255,.08)}
.my-stat-n{font-family:“Inter”,“Noto Sans JP”;font-size:20px;font-weight:900;color:#fff;line-height:1}
