/* ════════ STORAGE ════════ */
const HK="shikaku_pass_hist",SK="shikaku_streak",MH=10;
function gH(){try{return JSON.parse(localStorage.getItem(HK)||"[]")}catch{return[]}}
function sH(a){try{localStorage.setItem(HK,JSON.stringify(a))}catch{}}
function gP(s){
  try{
    const keys=[`dojo_${s.id}`,`dojo_v4_${s.id}`,`${s.id}_data`];
    for(const k of keys){
      const d=JSON.parse(localStorage.getItem(k)||"null");
      if(!d) continue;
      const h=(d.history||[]).slice(-200);
      if(!h.length) continue;
      return{rate:Math.round(h.filter(x=>x.correct).length/h.length*100),ans:d.totalAnswered||h.length};
    }
    return null;
  }catch{return null}
}
function getStreak(){
  try{
    const d=JSON.parse(localStorage.getItem(SK)||"{}");
    return{days:(d.days||[]).slice(-7),streak:d.streak||0};
  }catch{return{days:[],streak:0}}
}

/* ════════ UTILS ════════ */
let cTab="home",cRank="pop",cListCat="all",myActiveId=null;
function str(d){return"★".repeat(d)+"☆".repeat(5-d)}
function nc(i){return i===0?"gold":i===1?"silver":i===2?"bronze":""}
function tH(tags){
  const M={hot:["tp-hot","人気"],pop:["tp-pop","定番"],new:["tp-new","新着"],hard:["tp-hard","難関"]};
  return tags.map(t=>{const[c,l]=M[t]||["",""];return l?`<span class="tp ${c}">${l}</span>`:""}).join("");
}
function go(id,url){let h=gH();h=[id,...h.filter(x=>x!==id)].slice(0,MH);sH(h);window.location.href=url}
function stars(d){return"★".repeat(d)+'<span class="off">'+"★".repeat(5-d)+"</span>"}

